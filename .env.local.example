# AF Deep Research — Chatbot UI Configuration
# Per ARCHITECTURE.md Phase 11: Proxy routes through Next.js to control plane

# AF Control Plane (required)
# The backend URL for the AF Deep Research engine (Agent Field control plane)
AF_CONTROL_PLANE_URL=https://your-control-plane-url.com
AF_API_KEY=your-api-key-here

# OpenRouter Fusion (primary LLM provider)
# OpenRouter Fusion has built-in web search and fetch capabilities.
# No external search providers are needed.
OPENROUTER_API_KEY=sk-or-your-openrouter-api-key-here

# General Configuration (Optional)
NEXT_PUBLIC_USER_FILE_SIZE_LIMIT=10485760